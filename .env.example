# Copier ce fichier en `.env.local` (ignoré par git) et remplir les valeurs.
# Variables EXPO_PUBLIC_* sont injectées dans le bundle JS au build :
# ⚠️ tout le monde peut les extraire depuis l'IPA/APK. Restreindre l'usage
# côté provider (quotas, allowlist) plutôt que de compter sur la confidentialité.

# Gemini (Coach IA, génération de recettes, analyse de plat photo)
# Récupérer une clé sur https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# Cloudflare Workers AI (génération d'images de recettes via FLUX-1-schnell)
# 10 000 requêtes/jour gratuites par compte.
# 1. Créer un compte sur https://dash.cloudflare.com (gratuit)
# 2. Account ID : visible dans le dashboard, sidebar droite de n'importe quelle page
# 3. API token : https://dash.cloudflare.com/profile/api-tokens
#    → "Create Token" → template "Workers AI" (lecture suffisante)
EXPO_PUBLIC_CLOUDFLARE_ACCOUNT_ID=
EXPO_PUBLIC_CLOUDFLARE_API_TOKEN=
